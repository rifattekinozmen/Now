APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Laragon veya `php artisan serve`: http://127.0.0.1:8000 (Vite/`composer run dev` ile aynı taban)
APP_URL=http://127.0.0.1:8000

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Operasyonel bildirimler (sevkiyat gönderildi vb.) — logging.php kanal adı
# OPERATIONS_LOG_CHANNEL=single
# Slack Incoming Webhook (boş = Slack tarafı atlanır)
# OPERATIONS_SLACK_WEBHOOK_URL=
# OPERATIONS_SLACK_TIMEOUT=5

# =============================================================================
# Veritabanı — Laragon / yerel MySQL
# phpMyAdmin veya Laragon: oluşturduğunuz veritabanı adı ve kullanıcı ile eşleştirin.
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=now
DB_USERNAME=root
DB_PASSWORD=

# =============================================================================
# Alternatif: SQLite (Pest / CI / Composer setup, MySQL olmadan)
# =============================================================================
# Yerel test: `php artisan config:cache` kullandıysan önce `php artisan config:clear` çalıştır
# (veya TestCase otomatik siler); aksi halde önbellek eski DB_HOST değerini taşıyabilir.
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
# Üretimde zamanlanmış görevler (örn. `logistics:refresh-tcmb-rates` günlük 09:10): crontab veya supervisor ile `* * * * * php artisan schedule:run`

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Windows’ta phpredis yoksa: predis (projede yüklü)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# TotalEnergies (yakıt fiyatı — config/totalenergies.php schema_version + response_*_paths sözleşmesi)
TOTALENERGIES_ENABLED=false
# TOTALENERGIES_API_KEY=
# Yer tutucu URL reddedilir; gerçek taban adresi girin
# TOTALENERGIES_BASE_URL=
# TOTALENERGIES_QUOTE_PATH=/diesel-quote
# get (varsayılan) veya post — post ise gövde: config totalenergies.quote_query + quote_json_body birleşimi
# TOTALENERGIES_QUOTE_METHOD=get
# TOTALENERGIES_REGION=TR
# İsteğe bağlı il/ilçe (GET sorgu + POST JSON; API anahtar adları sözleşmeye göre quote_query ile değiştirilebilir)
# TOTALENERGIES_PROVINCE=
# TOTALENERGIES_DISTRICT=
# TOTALENERGIES_TIMEOUT=15
# İsteğe bağlı ek başlıklar (JSON): {"X-Contract-Id":"..."}
# TOTALENERGIES_EXTRA_HEADERS=
# Http::retry — toplam deneme ve bekleme (ms)
# TOTALENERGIES_RETRY_TIMES=2
# TOTALENERGIES_RETRY_SLEEP_MS=100
# Smoke: php artisan logistics:test-totalenergies [--json]
# Varsayılan para birimi yanıtta yoksa (TR pompa için genelde TRY)
# TOTALENERGIES_DEFAULT_CURRENCY=TRY
# İsteğe bağlı: müşteri API sözleşmesi / doküman URL (yalnızca referans; uygulama okumaz)
# TOTALENERGIES_CONTRACT_DOC_URL=
# Üretim doğrulama: gerçek base URL + API anahtarı ile `php artisan logistics:test-totalenergies [--json]`
# ve `tests/Feature/TotalEnergiesFuelQuoteIntegrationTest` (Http::fake ile).

# Logo Connect XML dışa aktarma — ortam değişkeni yok; alan eşlemesi `config/logo_export.php`.
# Rota: `admin.orders.export.logo.xml` (LogoErpExportService). Canlı şema farkı için müşteri Logo dokümantasyonu.

# Banka ekstresi — taranmış (görüntü-only) PDF: `App\Contracts\Finance\ScannedPdfOcrAdapter`
# Varsayılan `NullScannedPdfOcrAdapter` (`AppServiceProvider`). Üretimde Tesseract/bulut sınıfı bağlayın;
# metin katmanı: `BankStatementOcrService` + Smalot PdfParser.

# Müşteri / saha bildirimi: genel webhook + isteğe bağlı SMS / WhatsApp ayrı uçlar (HttpCustomerEngagementNotifier)
# auto | http | log | null | composite — null tam no-op; auto mevcut uç/bayrak mantığı
# CUSTOMER_ENGAGEMENT_DRIVER=auto
# composite: log + HTTP (aynı olayı LogCustomerEngagementNotifier ve HttpCustomerEngagementNotifier ile işler)
# CUSTOMER_ENGAGEMENT_DRIVER=composite
# Genel webhook (Twilio/Meta/özel köprü): JSON POST { channel, template, context }
# CUSTOMER_ENGAGEMENT_HTTP_ENDPOINT=
# CUSTOMER_ENGAGEMENT_HTTP_TIMEOUT=10
# İsteğe bağlı: Authorization Bearer (genel webhook POST)
# CUSTOMER_ENGAGEMENT_HTTP_BEARER=
# Gövde HMAC-SHA256 (X-Webhook-Signature: sha256=...)
# CUSTOMER_ENGAGEMENT_HTTP_SIGNATURE_SECRET=
# JSON gövdesi için X-Idempotency-Key (varsayılan: true)
# CUSTOMER_ENGAGEMENT_IDEMPOTENCY=true
# CUSTOMER_ENGAGEMENT_HTTP_RETRY_TIMES=2
# CUSTOMER_ENGAGEMENT_HTTP_RETRY_SLEEP_MS=100
# Ayrı kanal uçları (ör. Twilio Programmable SMS, Meta Cloud API) — aynı JSON gövdesi; üretimde HTTPS + Bearer token köprüde
# CUSTOMER_ENGAGEMENT_SMS_ENDPOINT=
# SMS için ayrı Bearer (boşsa CUSTOMER_ENGAGEMENT_HTTP_BEARER)
# CUSTOMER_ENGAGEMENT_SMS_BEARER=
# CUSTOMER_ENGAGEMENT_WHATSAPP_ENDPOINT=
# CUSTOMER_ENGAGEMENT_WHATSAPP_BEARER=
# Log kanalı (endpoint boşken CUSTOMER_ENGAGEMENT_LOG=true ile LogCustomerEngagementNotifier)
# CUSTOMER_ENGAGEMENT_LOG=false
# SMS/WhatsApp: true + endpoint doluysa HttpCustomerEngagementNotifier ilgili URL’e POST; yalnız bayrak (endpoint yoksa) log kanalına düşer
# SMS_NOTIFICATIONS_ENABLED=false
# WHATSAPP_NOTIFICATIONS_ENABLED=false

# Lojistik — iPOD sıkı modu (imza + GPS + foto yolu); şoför yorgunluk penceresi
# LOGISTICS_IPOD_STRICT=false
# LOGISTICS_MAX_DRIVING_HOURS=9
# LOGISTICS_FATIGUE_LOOKBACK_HOURS=24
# Banka ekstresi taranmış PDF OCR adaptörü (boşsa NullScannedPdfOcrAdapter)
# BANK_STATEMENT_OCR_ADAPTER=App\Services\Finance\TesseractOcrAdapter
